# Auto detect text files and ensure consistent line endings
* text=auto

# Force specific line endings for specific file types
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.svg text eol=lf
*.md text eol=lf

# Keep binary files unchanged
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary